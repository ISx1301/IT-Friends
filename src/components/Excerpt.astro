---
import { LOCALE, DEFAULT_LANG } from '../constants';

type Lang = keyof typeof LOCALE; // "uk" | "en"

interface Props {
  class?: string;
  wordLength?: number;
  lang?: Lang;
}

const props = Astro.props as Props;

const className = props.class ?? '';
const wordLength = props.wordLength;



// TODO: переписать функцию и константу resolvedLang / isLang


// type-guard, чтобы не было any
const isLang = (v: unknown): v is Lang =>
  typeof v === 'string' && (v === 'uk' || v === 'en');



// жёстко резолвим язык (fallback на DEFAULT_LANG -> 'uk')
const resolvedLang: Lang = isLang(props.lang)
  ? props.lang
  : isLang(DEFAULT_LANG)
    ? DEFAULT_LANG
    : 'uk';

const dict = LOCALE[resolvedLang];

const html = await Astro.slots.render('default');
const plainText = html.trim(); //replace(/<[^>]+>/g, '')
const words = plainText.split(/\s+/);
const shouldTruncate = wordLength !== undefined && words.length > wordLength;
const excerptedWords = shouldTruncate ? words.slice(0, wordLength) : words;
const excerptedText = excerptedWords.join(' ');
const readMoreHtml = `<span class="font-bold cursor-pointer read-more">${dict.readMore}</span>`;
---
<div class:list={['excerpt-container', className]}>
  <div class="text-base excerpt-text">
    <Fragment set:html={excerptedText + (shouldTruncate ? `... ${readMoreHtml}` : '')} />
  </div>
  <div class="hidden text-base full-text">
    <Fragment set:html={plainText} />
  </div>
</div>


{shouldTruncate && (
  <script>
    import { setupExcerpt } from '@scripts/excerpt.ts';
    setupExcerpt();
  </script>
)}