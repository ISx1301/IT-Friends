---
import Article from "@components/Article.astro";
import { BG_CLASSES, type BgColor } from "@/constants";
import { toHTML } from "@portabletext/to-html";

type PTSpan = { _type: 'span'; text: string; marks?: string[] };
type PTMarkDef = { _key: string; _type: string; href?: string };
type PTBlock = {
  _type: 'block';
  _key: string;
  style?: string;
  children: PTSpan[];
  markDefs?: PTMarkDef[];
};

type SanityImage = { alt?: string; url?: string };

type InterestingItem = {
  image?: SanityImage;
  title?: string;
  ptDescription?: PTBlock[];
  buttonText?: string;
  buttonHref?: string | null;
};

type InterestingThingsSection = {
  _type: "interestingThingsSection";
  _key: string;
  backgroundColor?: BgColor;
  heading?: string;
  paddingClass?: string; 
  items?: InterestingItem[];
};

export interface Props {
  section: InterestingThingsSection;
  anchorId?: string;
}

const { section, anchorId } = Astro.props as Props;

const bgClass = BG_CLASSES[(section.backgroundColor ?? "white") as BgColor];
const items = section.items ?? [];

const join = (...parts: (string | undefined | false)[]) =>
  parts.filter(Boolean).map(String).map(s => s.trim()).join(' ');

const isValidPadding = (s: string) =>
  s.split(/\s+/).every((t) => /^(?:[a-z]+:)?p[bt]-(?:px|0|[1-9]\d*)$/.test(t));

const padding = (section.paddingClass ?? '').trim();
if (!padding) throw new Error('[interestingThingsSection] Missing required "paddingClass" from Sanity');
if (!isValidPadding(padding)) throw new Error('[interestingThingsSection] Invalid "paddingClass" value');

const escapeAttr = (s?: string) =>
  (s ?? "").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

const normalizeRelHref = (v?: string | null) => {
  if (!v) return undefined;
  const trimmed = String(v).trim();
  if (!trimmed) return undefined;
  return trimmed.startsWith("/") ? trimmed : `/${trimmed}`;
};

const ptComponents = {
  block: {
    normal: ({ children }: any) =>
      `<p class="text-base lg:text-lg">${children}</p>`,
  },
  marks: {
    strong: ({ children }: any) => `<strong class="font-semibold">${children}</strong>`,
    em: ({ children }: any) => `<em class="italic">${children}</em>`,
    link: ({ value, children }: any) => {
      const href = escapeAttr(value?.href);
      if (!href) return children;
      return `<a class="text-primary-orange" href="${href}" target="_blank" rel="noopener noreferrer">${children}</a>`;
    },
  },
};

const itemsDescHtml = items.map((it) => toHTML(it?.ptDescription ?? [], { components: ptComponents }));
---

<section 
  id={anchorId} 
  class={join(bgClass, padding)}
  data-watch="fade-to-top" 
  data-watch-repeat
  data-watch-delay="320"
  data-watch-duration="1000"  
>
  <div class="container">
    {section.heading && (
      <div class="mx-auto mb-5 lg:mb-11 max-w-xs lg:max-w-2xl">
        <h2 class="font-secondary font-medium text-2xl lg:text-4xl text-center">
          {section.heading}
        </h2>
      </div>
    )}

    <div class="items-stretch gap-11 lg:gap-5 grid grid-cols-1 lg:grid-cols-2">
      {items.map((it, i) => {
        const href = normalizeRelHref(it?.buttonHref ?? undefined);
        return (
          <div class="h-full">
            <div class="flex flex-col gap-y-5 h-full">
              {it?.image?.url && (
                <div>
                  <img
                    class="rounded-lg w-full h-auto object-cover aspect-2/1"
                    src={it.image.url}
                    alt={it.image.alt ?? ""}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}

              {it?.title && (
                <div class="max-w-md">
                  <h3 class="font-bold text-xl">{it.title}</h3>
                </div>
              )}

              {(it?.ptDescription?.length ?? 0) > 0 && (
                <Article class="mt-auto max-w-sm text-left">
                  <div set:html={itemsDescHtml[i]} />
                </Article>
              )}

              {it?.buttonText && (
                href ? (
                  <a href={href} class="mt-auto px-1 py-3 lg:w-64 text-center transparent-btn">
                    {it.buttonText}
                  </a>
                ) : (
                  <button type="button" class="mt-auto px-1 py-3 lg:w-64 transparent-btn">
                    {it.buttonText}
                  </button>
                )
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
