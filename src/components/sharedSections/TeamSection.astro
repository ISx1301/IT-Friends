---
import { Image } from "astro:assets";
import EmblaCarousel from "@components/EmblaCarousel.astro";
import { BG_CLASSES, type BgColor } from "@/constants";
import { toHTML } from "@portabletext/to-html";

import { urlForImage } from "@/lib/sanityImage";          
import type { SanityImage } from "@/types/sanity";        

type PTSpan = { _type: 'span'; text: string; marks?: string[] };
type PTMarkDef = { _key: string; _type: string; href?: string };
type PTBlock = {
  _type: 'block';
  _key: string;
  style?: string;
  children: PTSpan[];
  markDefs?: PTMarkDef[];
};

type Member = {
  photo?: SanityImage;
  name?: string;
  subject?: string;
};

type TeamSectionData = {
  _type: "teamSection";
  _key: string;
  backgroundColor?: BgColor;
  heading?: string;
  paddingClass?: string; 
  description?: PTBlock[];
  members?: Member[];
};

export interface Props {
  section: TeamSectionData;
  anchorId?: string;
}

const { section, anchorId } = Astro.props as Props;

const bgClass = BG_CLASSES[(section.backgroundColor ?? "white") as BgColor];
const members = section.members ?? [];

const join = (...parts: (string | undefined | false)[]) =>
  parts.filter(Boolean).map(String).map(s => s.trim()).join(' ')

const isValidPadding = (s: string) =>
  s.split(/\s+/).every((t) => /^(?:[a-z]+:)?p[bt]-(?:px|0|[1-9]\d*)$/.test(t))

// padding (required in Sanity)
const padding = (section.paddingClass ?? '').trim()
if (!padding) throw new Error('[teamSection] Missing required "paddingClass" from Sanity')
if (!isValidPadding(padding)) throw new Error('[teamSection] Invalid "paddingClass" value')

const escapeAttr = (s?: string) =>
  (s ?? '').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const ptComponents = {
  block: { normal: ({ children }: any) => `<p>${children}</p>` },
  marks: {
    strong: ({ children }: any) => `<strong>${children}</strong>`,
    em: ({ children }: any) => `<em>${children}</em>`,
    link: ({ value, children }: any) => {
      const href = escapeAttr(value?.href);
      if (!href) return children;
      return `<a class="text-primary-orange" href="${href}" target="_blank" rel="noopener noreferrer">${children}</a>`;
    },
  },
};

const descriptionHtml = toHTML(section.description ?? [], { components: ptComponents });

// helper
const photoUrl = (img?: SanityImage, w = 600, h = 900) =>
  img?.asset
    ? urlForImage(img).width(w).height(h).fit('crop').auto('format').url()
    : undefined;
---

<section 
  id={anchorId} 
  class={join(bgClass, padding, "w-full overflow-visible ")}
  data-watch="fade-to-top" 
  data-watch-delay="320"
  data-watch-duration="1000"  
>
  <div class="container">
    <div class="m-auto mb-16 max-w-lg">
      {section.heading && (
        <h2 class="mb-8 font-secondary font-medium text-2xl lg:text-4xl text-center">
          {section.heading}
        </h2>
      )}
      {Boolean(section.description?.length) && (
        <div class="font-normal text-base text-center">
          <div set:html={descriptionHtml} />
        </div>
      )}
    </div>
  </div>

  <div class="p-0 container">
    <div class="flex lg:gap-5 pb-4 lg:overflow-hidden">
      <EmblaCarousel
        containerClass="!gap-0 -mr-5"
        options={{ breakpoints: { "(min-width: 1272px)": { slidesToScroll: 1, loop: true, align: "start" } } }}
      >
        <Fragment slot="slides">
          {members.map((m) => {
            const src = photoUrl(m.photo, 600, 900); // 2:3
            return (
              <div class="flex-grow-0 flex-shrink-0 min-w-80 lg:min-w-0 basis-1/2 lg:basis-1/4">
                <div class="flex flex-col gap-6 pr-5">
                  <div class="rounded-full aspect-2/3 overflow-hidden">
                    {src && (
                      <img
                        class="w-full h-full object-cover"
                        src={src}
                        alt={m.photo?.alt ?? ""}
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                  </div>

                  <div class="flex flex-col items-center">
                    {m.name && <h3 class="font-medium text-lg">{m.name}</h3>}
                    {m.subject && <p class="text-base">{m.subject}</p>}
                  </div>
                </div>
              </div>
            );
          })}
        </Fragment>

        <Fragment slot="controls">
          <div class="flex justify-around items-center gap-3 mt-14">
            <button class="embla__prev" type="button" aria-label="Previous slide">
              <Image class="w-8 h-8" src={import("@images/embla-prev2.svg")} format="svg" alt="prev-btn" />
            </button>
            <div class="flex justify-center items-center gap-1 bg-gray rounded-2xl w-24 h-9" aria-live="polite" aria-atomic="true">
              <p class="font-bold embla-current"></p>
              <p class="font-bold">/</p>
              <p class="font-bold embla-total"></p>
            </div>
            <button class="embla__next" type="button" aria-label="Next slide">
              <Image class="w-8 h-8" src={import("@images/embla-next2.svg")} alt="next-btn" format="svg" />
            </button>
          </div>
        </Fragment>
      </EmblaCarousel>
    </div>
  </div>
</section>
