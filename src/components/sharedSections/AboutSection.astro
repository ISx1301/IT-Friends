---
import Article from '@components/Article.astro'
import {
  BG_CLASSES,
  HEADING_ALIGN_CLASSES,
  ABOUT_LAYOUT_ROW_CLASSES,
  BADGE_BORDER_CLASSES,
  type BgColor,
  type Align,
  type AboutLayout,
  type BadgeBorderColor,
} from '@/constants'
import { toHTML } from '@portabletext/to-html'

type PTSpan = { _type: 'span'; _key: string; text: string; marks?: string[] }
type PTLink = { _key: string; _type: 'link'; href: string; openInNewTab?: boolean }
type PTBlock = {
  _type: 'block'
  _key: string
  style?: string
  children: PTSpan[]
  markDefs?: PTLink[]
}

const ptComponents = {
  marks: {
    em: ({ children }: any) => `<em>${children}</em>`,
    strong: ({ children }: any) => `<strong>${children}</strong>`,
    link: ({ value, children }: any) => {
      const href = value?.href || '#'
      const blank = value?.openInNewTab
      const target = blank ? ' target="_blank" rel="noopener noreferrer"' : ''
      return `<a href="${href}" class="underline hover:no-underline"${target}>${children}</a>`
    },
  },
}

type OrderKind = 'h3' | 'paragraphs' | 'h4' | 'badges';

type AboutSectionData = {
  _type: 'aboutSection';
  _key: string;
  backgroundColor?: BgColor;
  heading?: string;
  headingAlign?: Align;
  layout?: AboutLayout;
  image?: { url?: string; alt?: string };
  content?: {
    h3?: string;
    paragraphs?: PTBlock[];
    h4?: string;
    badges?: { borderColor?: BadgeBorderColor; items?: string[] };
    order?: { kind: OrderKind }[];
  };
};

export interface Props { 
  section: AboutSectionData 
  anchorId?: string 
}

const { section, anchorId } = Astro.props as Props


const bgClass = BG_CLASSES[(section.backgroundColor ?? 'white') as BgColor];
const headingAlignClass = HEADING_ALIGN_CLASSES[(section.headingAlign ?? 'left') as Align];
const rowClass = ABOUT_LAYOUT_ROW_CLASSES[(section.layout ?? 'image-left') as AboutLayout];
const badgeBorderClass = BADGE_BORDER_CLASSES[(section.content?.badges?.borderColor ?? 'mint') as BadgeBorderColor];

const order: OrderKind[] = section.content?.order?.length
  ? section.content.order.map((i) => i.kind)
  : ['h3', 'paragraphs', 'h4', 'badges'];

const paragraphs = (section.content?.paragraphs ?? []) as PTBlock[];
const badges = section.content?.badges?.items ?? [];
---

<section id={anchorId} class={`py-20 lg:py-32 ${bgClass}`}>
  <div class="container">
    <div class={`mb-8 basis-1/4 lg:basis-1/12 ${headingAlignClass}`}>
      {section.heading && (
        <h2 class="font-secondary font-medium text-2xl lg:text-3xl">
          {section.heading}
        </h2>
      )}
    </div>

    <div class={`flex flex-col ${rowClass} gap-8 basis-1/4 lg:basis-1/12`}>

      <div class="lg:basis-6/12 basis-1/4">
        {section.image?.url && (
          <img
            src={section.image.url}
            alt={section.image.alt ?? ''}
            loading="lazy"
            decoding="async"
            class="w-full h-auto"
          />
        )}
      </div>

      <div class="flex flex-col lg:basis-6/12 basis-1/4">
        {order.map((kind) => {
          switch (kind) {
            case 'h3':
              return section.content?.h3 ? (
                <h3 class="mb-5 font-secondary font-semibold text-xl lg:text-3xl">
                  {section.content.h3}
                </h3>
              ) : null;

            case 'paragraphs': {
              if (!paragraphs.length) return null
              const html = toHTML(paragraphs, { components: ptComponents })
              return (
                <div class="mb-12 lg:mb-auto">
                  <Article>
                    <div class="max-w-none prose" set:html={html} />
                  </Article>
                </div>
              )
            }

            case 'h4':
              return section.content?.h4 ? (
                <h4 class="mt-auto mb-4 font-bold text-2xl">
                  {section.content.h4}
                </h4>
              ) : null;

            case 'badges':
              return badges.length ? (
                <div class="gap-4 grid grid-cols-2 mb-12 lg:mb-auto lg:[grid-template-columns:max-content_max-content]">
                  {badges.map((b) => (
                    <span class={`block w-full px-4 lg:px-6 py-1 lg:py-2 border ${badgeBorderClass} rounded-3xl lg:w-[12rem] font-play font-normal text-xl text-center`}>
                      {b}
                    </span>
                  ))}
                </div>
              ) : null;
          }
        })}
      </div>
    </div>
  </div>
</section>