---
import Article from "@components/Article.astro";
import Excerpt from "@components/Excerpt.astro"
import { Image } from "astro:assets";
import EmblaCarousel from "@components/EmblaCarousel.astro";
import { BG_CLASSES, type BgColor } from "@/constants";
import { toHTML } from "@portabletext/to-html";

type PTSpan = { _type: 'span'; text: string; marks?: string[] };
type PTMarkDef = { _key: string; _type: string; href?: string };
type PTBlock = {
  _type: 'block';
  _key: string;
  style?: string;
  children: PTSpan[];
  markDefs?: PTMarkDef[];
};

type SanityImage = { url?: string; alt?: string };
type Review = { avatar?: SanityImage; name?: string; text?: PTBlock[] };

type ReviewsSectionData = {
  _type: "reviewsSection";
  _key: string;
  backgroundColor?: BgColor;
  heading?: string;
  paddingClass?: string; // 👈 новое
  paragraphs?: PTBlock[];
  buttonText?: string;
  reviews?: Review[];
};

export interface Props { 
  section: ReviewsSectionData 
  anchorId?: string 
}

const { section, anchorId } = Astro.props as Props

const bgClass = BG_CLASSES[(section.backgroundColor ?? "white") as BgColor];
const reviews = section.reviews ?? [];

const join = (...parts: (string | undefined | false)[]) =>
  parts.filter(Boolean).map(String).map(s => s.trim()).join(' ')

const isValidPadding = (s: string) =>
  s.split(/\s+/).every((t) => /^(?:[a-z]+:)?p[bt]-(?:px|0|[1-9]\d*)$/.test(t))

// padding (required in Sanity)
const padding = (section.paddingClass ?? '').trim()
if (!padding) throw new Error('[reviewsSection] Missing required "paddingClass" from Sanity')
if (!isValidPadding(padding)) throw new Error('[reviewsSection] Invalid "paddingClass" value')

const escapeAttr = (s?: string) =>
  (s ?? '').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const ptComponents = {
  block: { normal: ({ children }: any) => `<p>${children}</p>` },
  marks: {
    strong: ({ children }: any) => `<strong>${children}</strong>`,
    em: ({ children }: any) => `<em>${children}</em>`,
    link: ({ value, children }: any) => {
      const href = escapeAttr(value?.href);
      if (!href) return children;
      return `<a class="text-primary-orange" href="${href}" target="_blank" rel="noopener noreferrer">${children}</a>`;
    },
  },
};

const paragraphsHtml = toHTML(section.paragraphs ?? [], { components: ptComponents });

const STRIPE_CLASSES = ["bg-primary-green", "bg-primary-orange", "bg-span-gray"] as const;
const stripeClassByIndex = (i: number) => STRIPE_CLASSES[i % STRIPE_CLASSES.length];

const seg = Astro.url.pathname.replace(/^\/+|\/+$/g, '').split('/')[0];
const lang = seg === 'en' ? 'en' : 'uk';
---

<section 
  id={anchorId} 
  class={join(bgClass, padding, 'overflow-hidden')} 
  id="reviews"
  data-watch="fade-to-top" 
  data-watch-repeat
  data-watch-delay="320"
  data-watch-duration="1000"  
>
  <div class="container">
    <div class="flex lg:flex-row flex-col justify-between">

      <div class="py-14 basis-4/12">
        {section.heading && (
          <h2 class="mb-8 font-secondary font-medium text-2xl lg:text-3xl lg:text-left text-center">
            {section.heading}
          </h2>
        )}

        {Boolean(section.paragraphs?.length) && (
          <Article class="mb-11 lg:text-left text-center">
            <div set:html={paragraphsHtml} />
          </Article>
        )}

        {section.buttonText && (
          <button type="button" class="hidden lg:inline-block px-7 py-3 leading-none transparent-btn">
            {section.buttonText}
          </button>
        )}
      </div>

      <div class="flex flex-row lg:flex-col justify-between gap-5 basis-6/12">
        <EmblaCarousel
          containerClass="lg:flex-col overflow-visible"
          options={{ breakpoints: { "(min-width: 1272px)": { active: false } } }}
        >
          <Fragment slot="slides">
            {reviews.map((rv, index) => {
              const isEven = index % 2 === 0;
              const stripe = stripeClassByIndex(index);
              const cardClass =
                `embla__slide flex lg:flex-row flex-col lg:justify-between items-center gap-5 lg:gap-0
                 bg-white shadow-none lg:shadow-md border border-gray lg:border-none rounded-md
                 w-[31rem] min-w-full lg:min-w-0 ${isEven ? "ml-auto" : ""}`;

              const reviewHtml = toHTML(rv.text ?? [], { components: ptComponents });

              return (
                <div class={cardClass}>
                  <div class={`${stripe} rounded-md w-full lg:w-2 h-2 lg:h-[-webkit-fill-available]`}></div>

                  <div class="my-3">
                    {rv.avatar?.url && (
                      <img
                        class="rounded-full w-16 h-16 object-cover"
                        src={rv.avatar.url}
                        alt={rv.avatar.alt ?? ""}
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                    {rv.name && <p class="font-normal">{rv.name}</p>}
                  </div>

                  <div class="max-w-xs">
                    <Article>
                      <Excerpt lang={lang} wordLength={15}>
                        <div class="text-center lg:text-start" set:html={reviewHtml} />
                      </Excerpt>
                    </Article>
                  </div>

                  {section.buttonText && (
                    <button
                      type="button"
                      class="lg:hidden my-6 py-5 border-black w-11/12 leading-none transparent-btn"
                    >
                      {section.buttonText}
                    </button>
                  )}
                </div>
              );
            })}
          </Fragment>

          <Fragment slot="controls">
            <div class="lg:hidden flex justify-center items-center gap-3 mt-4">
              <button class="embla__prev" type="button" aria-label="Previous slide">
                <Image class="w-6 h-6" src={import("@images/embla-prev-svg.svg")} alt="prev-btn" />
              </button>
              <div class="flex justify-center items-center gap-1 bg-gray rounded-2xl w-24 h-9" aria-live="polite" aria-atomic="true">
                <p class="font-bold text-primary-green embla-current"></p>
                <p class="font-bold">/</p>
                <p class="font-bold embla-total"></p>
              </div>
              <button class="embla__next" type="button" aria-label="Next slide">
                <Image class="w-6 h-6" src={import("@images/embla-next-svg.svg")} alt="next-btn" />
              </button>
            </div>
          </Fragment>
        </EmblaCarousel>
      </div>
    </div>
  </div>
</section>
