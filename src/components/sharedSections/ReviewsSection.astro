---
import Article from "@components/Article.astro";
import { Image } from 'astro:assets';

type ImageReviewsType = {
  src: ImageMetadata;
  alt?: string;
};

type cardItem = {
  divBg: 'orange' | 'green' | 'gray';
  image: ImageReviewsType;
  name: string;
  description: string;
  videoReview: string;
};

type Props = {
  sectionPaddingsStyle: 'withPaddings' | 'withoutPaddings';
  sectionBgStyle: 'white' | 'gray';
  titleText: string;
  reviewsDescription: string[];
  videoReview: string;
  cards: cardItem[];
};

const {
  sectionPaddingsStyle,
  sectionBgStyle,
  titleText,
  reviewsDescription,
  videoReview,
  cards,
} = Astro.props;

const sectionClassMap = {
  withPaddings: 'py-16 lg:py-32',
  withoutPaddings: 'py-0',
};

const sectionBgMap = {
  white: 'bg-section-white',
  gray: 'bg-gray',
};

const reviewDivStyle = {
  orange: 'bg-primary-orange',
  green: 'bg-primary-green',
  gray: 'bg-span-gray',
};
---

<section class={`${sectionClassMap[sectionPaddingsStyle]} ${sectionBgMap[sectionBgStyle]} overflow-hidden`} id="reviews">
  <div class="container">
    <div class="flex lg:flex-row flex-col justify-between">
  
      <div class="py-14 basis-4/12">
        <h2 class="mb-8 font-secondary font-medium text-2xl lg:text-3xl lg:text-left text-center">{titleText}</h2>
        <Article class="mb-11 lg:text-left text-center">
          {reviewsDescription.map(text => <p>{text}</p>)}
        </Article>
        <button type="button" class="hidden lg:inline-block px-7 py-3 leading-none transparent-btn">{videoReview}</button>
      </div>

      <div class="basis-6/12">
        <div class="embla">
          <div class="mb-7 embla__viewport">
            <div class="flex flex-row lg:flex-col justify-between gap-5 basis-6/12 embla__container">
              {cards.map((review, index) => {
                const isEven = index % 2 === 0;
                const cardClass = `embla__slide flex lg:flex-row flex-col lg:justify-between items-center gap-5 lg:gap-0 bg-white shadow-none lg:shadow-md border border-gray lg:border-none rounded-md w-[31rem] min-w-full lg:min-w-0 ${isEven ? 'ml-auto' : ''}`;
                return (
                  <div class={cardClass}>
                    <div class={`${reviewDivStyle[review.divBg]} rounded-md w-full lg:w-2 h-2 lg:h-[-webkit-fill-available]`}></div>
                    <div class="my-3">
                      <Image
                        class="rounded-full w-16 h-16 object-cover"
                        src={review.image.src}
                        format="webp"
                        alt={review.image.alt || 'image'}
                      />
                      <p class="font-normal">{review.name}</p>
                    </div>
                    <div class="max-w-xs">
                      <p class="font-normal text-base lg:text-left text-center">{review.description}</p>
                    </div>
                    <button type="button" class="lg:hidden my-6 px-28 py-5 border-black leading-none transparent-btn">{review.videoReview}</button>
                  </div>
                );
              })}
            </div>
          </div>

          <div class="lg:hidden flex justify-center items-center gap-3">
            <button class="embla__prev" type="button">
              <Image
                class="w-3 h-6"
                src={import("@images/embla-prev-svg.svg")}
                alt='prev-btn'
              />
            </button>
            <div>
            <div class="flex justify-center items-center gap-1 bg-gray rounded-2xl w-24 h-9">
              <p id="embla-current" class="font-bold text-primary-green"></p>
              <p class="font-bold">/</p>
              <p id="embla-total" class="font-bold"></p>
            </div>
            </div>
            <button type="button" class="embla__next">
              <Image
                class="w-3 h-6"
                src={import("@images/embla-next-svg.svg")}
                alt='prev-btn'
              />
            </button>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initEmbla } from '@scripts/embla.ts';

  if (typeof window !== 'undefined') {
    window.addEventListener('load', () => {
      initEmbla('.embla');
    });
  }
</script>





