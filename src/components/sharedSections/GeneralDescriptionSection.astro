---
import Article from "@components/Article.astro";
import { BG_CLASSES, type BgColor } from "@/constants";
import { toHTML } from "@portabletext/to-html";

type PTSpan = { _type: 'span'; text: string; marks?: string[] };
type PTMarkDef = { _key: string; _type: string; href?: string };
type PTBlock = {
  _type: 'block';
  _key: string;
  style?: string;
  children: PTSpan[];
  markDefs?: PTMarkDef[];
};

type SanityImage = { alt?: string; url?: string };

type Card = {
  image?: SanityImage;
  title?: string;
  description?: PTBlock[];
};

type GeneralDescriptionSection = {
  _type: "generalDescriptionSection";
  _key: string;
  backgroundColor?: BgColor;
  heading?: string;
  paddingClass?: string; 
  cards?: Card[];
  buttonText?: string;
  buttonClass?: string;
};

export interface Props {
  section: GeneralDescriptionSection;
  anchorId?: string;
}

const { section, anchorId } = Astro.props as Props;

const bgClass = BG_CLASSES[(section.backgroundColor ?? "white") as BgColor];
const cards = section.cards ?? [];

const join = (...parts: (string | undefined | false)[]) =>
  parts.filter(Boolean).map(String).map(s => s.trim()).join(' ')
const isValidPadding = (s: string) =>
  s.split(/\s+/).every((t) => /^(?:[a-z]+:)?p[bt]-(?:px|0|[1-9]\d*)$/.test(t))

// padding (required in Sanity)
const padding = (section.paddingClass ?? '').trim()
if (!padding) throw new Error('[generalDescriptionSection] Missing required "paddingClass" from Sanity')
if (!isValidPadding(padding)) throw new Error('[generalDescriptionSection] Invalid "paddingClass" value')

const escapeAttr = (s?: string) =>
  (s ?? '').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const ptComponents = {
  block: { normal: ({ children }: any) => `<p>${children}</p>` },
  marks: {
    strong: ({ children }: any) => `<strong>${children}</strong>`,
    em: ({ children }: any) => `<em>${children}</em>`,
    link: ({ value, children }: any) => {
      const href = escapeAttr(value?.href);
      if (!href) return children;
      return `<a class='text-primary-orange' href="${href}" target="_blank" rel="noopener noreferrer">${children}</a>`;
    },
  },
};

const descriptionHtmlByIndex = cards.map((c) =>
  toHTML(c?.description ?? [], { components: ptComponents })
);

const baseBtn =
  "px-5 py-4 font-secondary font-medium text-lg orange-btn form-open";
const extraBtn = (section.buttonClass ?? "").trim();
const finalBtnClass = (baseBtn + " " + extraBtn).trim();
---

<section id={anchorId} class={join(bgClass, padding)}>
  <div class="container">

    {section.heading && (
      <div class="flex justify-center mx-auto mb-6 lg:mb-8 py-0.5">
        <h2 class="mb-3 lg:mb-7 font-secondary font-medium text-2xl lg:text-4xl text-center">
          {section.heading}
        </h2>
      </div>
    )}

    {cards.length > 0 && (
      <div class="flex lg:flex-row flex-col items-stretch gap-5">
        {cards.map((card, idx) => (
          <div class="flex flex-col items-center gap-3 lg:gap-7 bg-white shadow-lg px-8 lg:px-6 py-8 lg:py-10 rounded-lg w-full">
            {card.image?.url && (
              <img
                src={card.image.url}
                alt={card.image.alt ?? ""}
                loading="lazy"
                decoding="async"
                class="max-h-28 object-contain"
              />
            )}

            {card.title && (
              <h3 class="font-secondary font-semibold text-xl lg:text-2xl text-center">
                {card.title}
              </h3>
            )}

            {(card.description?.length ?? 0) > 0 && (
              <Article class="font-medium text-base lg:text-lg text-center">
                <div set:html={descriptionHtmlByIndex[idx]} />
              </Article>
            )}
          </div>
        ))}
      </div>
    )}

    {section.buttonText && (
      <div class="flex justify-center mt-8">
        <button class={finalBtnClass} type="button">
          {section.buttonText}
        </button>
      </div>
    )}

  </div>
</section>
