---
import { BG_CLASSES, type BgColor } from '@/constants';
import { toHTML } from '@portabletext/to-html';

type PTSpan = { _type: 'span'; text: string; marks?: string[] };
type PTMarkDef = { _key: string; _type: string; href?: string };
type PTBlock = {
  _type: 'block';
  _key: string;
  style?: string;
  children: PTSpan[];
  markDefs?: PTMarkDef[];
};

type SanityImage = { url?: string; alt?: string };
type Card = { image?: SanityImage; title?: string; description?: PTBlock[] };

type SectionData = {
  _type: 'peculiaritiesSection';
  _key: string;
  backgroundColor?: BgColor;
  heading?: string;
  paddingClass?: string; 
  mainImage?: SanityImage;
  row1?: Card[];
  row2?: Card[];
};

export interface Props { 
  section: SectionData 
  anchorId?: string 
}

const { section, anchorId } = Astro.props as Props

const bgClass = BG_CLASSES[(section.backgroundColor ?? 'white') as BgColor];
const left = section.row1 ?? [];
const right = section.row2 ?? [];

const join = (...parts: (string | undefined | false)[]) =>
  parts.filter(Boolean).map(String).map(s => s.trim()).join(' ')

const isValidPadding = (s: string) =>
  s.split(/\s+/).every((t) => /^(?:[a-z]+:)?p[bt]-(?:px|0|[1-9]\d*)$/.test(t))

// padding (required in Sanity)
const padding = (section.paddingClass ?? '').trim()
if (!padding) throw new Error('[peculiaritiesSection] Missing required "paddingClass" from Sanity')
if (!isValidPadding(padding)) throw new Error('[peculiaritiesSection] Invalid "paddingClass" value')

const escapeAttr = (s?: string) =>
  (s ?? '').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const ptComponents = {
  block: { normal: ({ children }: any) => `<p>${children}</p>` },
  marks: {
    strong: ({ children }: any) => `<strong>${children}</strong>`,
    em: ({ children }: any) => `<em>${children}</em>`,
    link: ({ value, children }: any) => {
      const href = escapeAttr(value?.href);
      if (!href) return children;
      return `<a class="text-primary-orange" href="${href}" target="_blank" rel="noopener noreferrer">${children}</a>`;
    },
  },
};
---

<section 
  id={anchorId} 
  class={join(bgClass, padding)}
  data-watch="fade-to-top" 
  data-watch-repeat
  data-watch-delay="300"
  data-watch-duration="1000"
>
  <div class="container">
    <div class="w-full">
      {section.heading && (
        <h2 class="mb-9 lg:mb-14 text-3xl lg:text-4xl text-center">{section.heading}</h2>
      )}
    </div>

    <div class="gap-5 grid grid-cols-1 lg:grid-cols-3 lg:grid-rows-2">
      {left.slice(0,2).map((card, i) => {
        const html = toHTML(card.description ?? [], { components: ptComponents })
        const row = i === 0 ? 'lg:row-start-1' : 'lg:row-start-2'
        return (
          <div class={`bg-white px-5 py-7 rounded-md w-full ${row} lg:col-start-1 flex flex-col h-full`}>
            {card.image?.url && (
              <img class="mb-3 rounded-md w-12 object-cover"
                src={card.image.url}
                alt={card.image.alt ?? ''} 
                loading="lazy" 
                decoding="async"/>
            )}
            {card.title && <h3 class="mb-2 font-semibold text-lg lg:text-xl">{card.title}</h3>}
            <div class="max-w-none prose grow" set:html={html}></div>
          </div>
        )
      })}

      <div class="lg:col-start-2 row-span-1 lg:row-span-2 rounded-md overflow-hidden">
        {section.mainImage?.url && (
          <img class="w-full h-52 lg:h-full object-cover"
              src={section.mainImage.url} 
              alt={section.mainImage.alt ?? ''} 
              loading="lazy" 
              decoding="async"/>
        )}
      </div>

      {right.slice(0,2).map((card, i) => {
        const html = toHTML(card.description ?? [], { components: ptComponents })
        const row = i === 0 ? 'lg:row-start-1' : 'lg:row-start-2'
        return (
          <div class={`bg-white px-5 py-7 rounded-md w-full ${row} lg:col-start-3 flex flex-col h-full`}>
            {card.image?.url && (
              <img class="mb-3 rounded-md w-12 object-cover"
                  src={card.image.url} 
                  alt={card.image.alt ?? ''} 
                  loading="lazy" 
                  decoding="async"/>
            )}
            {card.title && <h3 class="mb-2 font-semibold text-lg lg:text-xl">{card.title}</h3>}
            <div class="max-w-none prose grow" set:html={html}></div>
          </div>
        )
      })}
    </div>
  </div>
</section>
