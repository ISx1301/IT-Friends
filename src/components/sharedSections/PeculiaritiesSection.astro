---
import { Image } from 'astro:assets';

type ImagePeculiaritiesType = {
  src: ImageMetadata;
  alt?: string;
};

type cardItemFirstBlock = {
  image: ImagePeculiaritiesType;
  subHeading: string;
  description: string;
}

type cardItemSecondBlock = {
  image: ImagePeculiaritiesType;
  subHeading: string;
  description: string;
}

type Props = {
  sectionPaddingsStyle: 'withPaddings' | 'withoutPaddings';
  sectionBgStyle: 'gradient' | 'gray';
  titleText: string;
  leftCard: cardItemFirstBlock[];
  mainImage: ImagePeculiaritiesType;
  rightCard: cardItemSecondBlock[];
}


const {
  sectionPaddingsStyle,
  sectionBgStyle,
  mainImage,
  titleText,
  leftCard,
  rightCard,
} = Astro.props;

const sectionClassMap = {
  withPaddings: 'py-11 lg:py-16',
  withoutPaddings: 'py-0',
};

const sectionBgMap= {
  gradient: 'bg-gradient-to-b from-gradient-from to-gradient-to',
  gray: 'bg-gray'
}
---


<!-- Peculiarities section-->

  <section class={`${sectionBgMap[sectionBgStyle]} ${sectionClassMap[sectionPaddingsStyle]}`}>
    <div class="container">
      <div class="w-full">
        <h2 class="mb-9 lg:mb-14 text-3xl lg:text-4xl text-center">{titleText}</h2> 
      </div>
      <div class="flex lg:flex-row flex-col gap-5">
        <div class="flex flex-col gap-y-5 basis-full lg:basis-1/3">
          {leftCard.map((card) => {
            return (
            <div class="bg-white px-5 py-7 rounded-md w-full basis-full">
              <Image
                src={card.image.src}
                format="webp"
                alt={card.image.alt || 'image'}
                class=""
              />
              <h3 class="mb-1 font-semibold text-lg lg:text-xl">{card.subHeading}</h3>
              <p class="mb-0 font-normal text-base lg:text-lg lg:leading-5">{card.description}</p>
            </div>
            )
          })}
        </div>
        <div class="flex flex-col gap-y-5 basis-full lg:basis-1/3">
          <div class="rounded-md h-52 lg:h-full overflow-hidden">
            <Image
              src={mainImage.src}
              format="webp"
              alt={mainImage.alt || 'image'}
              class="w-full"
            />
          </div>
        </div>
        <div class="flex flex-col gap-y-5 basis-full lg:basis-1/3">
          {rightCard.map((card) => {
            return (
            <div class="bg-white px-5 py-7 rounded-md w-full basis-full">
              <Image
                src={card.image.src}
                format="webp"
                alt={card.image.alt || 'image'}
                class=""
              />
              <h3 class="mb-1 font-semibold text-lg lg:text-xl">{card.subHeading}</h3>
              <p class="mb-0 font-normal text-base lg:text-lg lg:leading-5">{card.description}</p>
            </div>
            )
          })}
        </div>      
      </div>
    </div>
  </section>
