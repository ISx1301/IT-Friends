---
import Article from "@components/Article.astro";
import { BG_CLASSES, type BgColor } from "@/constants";
import { toHTML } from "@portabletext/to-html";

type PTSpan = { _type: 'span'; text: string; marks?: string[] };
type PTMarkDef = { _key: string; _type: string; href?: string };
type PTBlock = {
  _type: 'block';
  _key: string;
  style?: string;
  children: PTSpan[];
  markDefs?: PTMarkDef[];
};
type SanityImage = { alt?: string; url?: string };
type Kind = 'logo' | 'badge' | 'heading' | 'description' | 'button' | 'image';

type HeroZoomImageSection = {
  _type: "heroZoomImageSection";
  _key: string;
  backgroundColor?: BgColor;
  paddingClass?: string; 
  logo?: SanityImage;
  badgeText?: string;
  heading?: string;
  description?: PTBlock[];
  buttonText?: string;
  mainImage?: SanityImage;
  order?: { kind?: Kind }[];
};

export interface Props { 
  section: HeroZoomImageSection 
  anchorId?: string 
}

const { section, anchorId } = Astro.props as Props;

const bgClass = BG_CLASSES[(section.backgroundColor ?? "white") as BgColor];

const join = (...parts: (string | undefined | false)[]) =>
  parts.filter(Boolean).map(String).map(s => s.trim()).join(' ')
const isValidPadding = (s: string) =>
  s.split(/\s+/).every((t) => /^(?:[a-z]+:)?p[bt]-(?:px|0|[1-9]\d*)$/.test(t))

// padding (required in Sanity)
const padding = (section.paddingClass ?? '').trim()
if (!padding) throw new Error('[heroZoomImageSection] Missing required "paddingClass" from Sanity')
if (!isValidPadding(padding)) throw new Error('[heroZoomImageSection] Invalid "paddingClass" value')

const escapeAttr = (s?: string) =>
  (s ?? '').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const ptComponents = {
  block: { normal: ({ children }: any) => `<p>${children}</p>` },
  marks: {
    strong: ({ children }: any) => `<strong>${children}</strong>`,
    em: ({ children }: any) => `<em>${children}</em>`,
    link: ({ value, children }: any) => {
      const href = escapeAttr(value?.href);
      if (!href) return children;
      return `<a class='text-primary-orange' href="${href}" target="_blank" rel="noopener noreferrer">${children}</a>`;
    },
  },
};

const descriptionHtml = toHTML(section.description ?? [], { components: ptComponents });

const defaultOrder: Kind[] = ['logo','badge','heading','description','button','image'];
const order: Kind[] = (section.order?.map(i => i?.kind).filter(Boolean) as Kind[])?.length
  ? (section.order!.map(i => i!.kind!) as Kind[])
  : defaultOrder;

// , 'relative mt-11 lg:mt-16' 
---
<section id={anchorId} class={join(bgClass, padding)}>
  <div class="container">
    {order.map((k) => {
      switch (k) {
        case 'logo':
          return section.logo?.url && (
            <div class="flex justify-center mb-3">
              <img
                src={section.logo.url}
                alt={section.logo.alt ?? ""}
                loading="lazy"
                decoding="async"
                class="max-h-16 object-contain"
              />
            </div>
          );

        case 'badge':
          return section.badgeText && (
            <div class="flex justify-center mb-6 lg:mb-8">
              <div class="inline-block bg-transparent-btn-hover-bg px-2 py-0.5 rounded">
                <p class="text-sm lg:text-base">{section.badgeText}</p>
              </div>
            </div>
          );

        case 'heading':
          return section.heading && (
            <div class="flex justify-center mb-6 lg:mb-7">
              <h1 class="lg:w-2/3 font-secondary font-medium text-2xl lg:text-4xl text-center">
                {section.heading}
              </h1>
            </div>
          );

        case 'description':
          return Boolean(section.description?.length) && (
            <div class="mx-auto mb-11 lg:mb-11 max-w-md">
              <Article class="font-normal text-lg text-center">
                <div set:html={descriptionHtml} />
              </Article>
            </div>
          );

        case 'button':
          return section.buttonText && (
            <div class="flex justify-center mb-11 basis-1/4 lg:basis-1/12">
              <button class="px-5 py-4 font-secondary font-medium text-lg orange-btn form-open" type="button">
                {section.buttonText}
              </button>
            </div>
          );

        case 'image':
          return section.mainImage?.url && (
            <div class="relative mb-6 lg:mb-0 rounded-xl aspect-5/2 overflow-hidden">
              <div class="z-10 absolute inset-0 bg-black opacity-40"></div>
              <img
                class="z-0 relative w-full h-full object-cover animate-zoom-pulse"
                src={section.mainImage.url}
                alt={section.mainImage.alt ?? ""}
                loading="eager"
                decoding="async"
              />
            </div>
          );

        default:
          return null;
      }
    })}
  </div>
</section>
