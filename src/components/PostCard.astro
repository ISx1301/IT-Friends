---
const { post } = Astro.props;

function getPreview(p: { previewContent?: string; content?: any[] }) {
  if (!p) return '';
  if (typeof p.previewContent === 'string' && p.previewContent.trim()) {
    return p.previewContent.trim().slice(0, 220);
  }
  try {
    if (Array.isArray(p.content) && p.content.length > 0) {
      const first = p.content[0];
      if (first?.children && Array.isArray(first.children)) {
        return first.children.map((c: { text: any; }) => c?.text ?? '').join('').slice(0, 220);
      }
    }
  } catch (e) {}
  return '';
}
const preview = getPreview(post);

const slug = typeof post.slug === 'string' ? post.slug : post.slug?.current || '';

let formattedDate = '';
if (post.date) {
  try {
    const d = new Date(post.date);
    formattedDate = d.toLocaleDateString('uk-UA', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
  } catch (e) {
    formattedDate = post.date.toLocaleDateString();
  }
}
---

<a href={`/uk/blog/${slug}`} class="flex flex-col mb-11 h-full post-card">
  <div class="rounded-lg w-full h-64 lg:h-72 overflow-hidden">
    <img
      src={post.image.url}
      alt={post.image.alt || post.title}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-center object-cover"
    />
  </div>

  <h3 class="mt-3 mb-4 font-bold text-xl">{post.title}</h3>

  <div class="flex flex-col flex-1 mt-0">
    <p class="opacity-80 mt-0 mb-2 text-lg line-clamp-3">{preview}</p>

    {formattedDate && (
      <time class="block text-gray-400 text-sm">
        {formattedDate}
      </time>
    )}
  </div>
</a>
