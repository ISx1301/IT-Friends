---
import EmblaCarousel from "@components/EmblaCarousel.astro";
import Article from "@components/Article.astro";
import { BG_CLASSES, type BgColor } from "@/constants";
import { Image } from 'astro:assets';

type SanityImage = { alt?: string; url?: string };
type AddressItem = {
  image?: SanityImage;
  title?: string;
  address?: string;
  phone?: string;
  href?: string;
};
type SchoolAddressesSection = {
  _type: "schoolAddressesSection";
  _key: string;
  backgroundColor?: BgColor;
  heading?: string;
  paddingClass?: string; 
  items?: AddressItem[];
};

export interface Props {
  section: SchoolAddressesSection;
  anchorId?: string;
}

const { section, anchorId } = Astro.props as Props;
const bgClass = BG_CLASSES[(section.backgroundColor ?? "white") as BgColor];
const items = section.items ?? [];

const join = (...parts: (string | undefined | false)[]) =>
  parts.filter(Boolean).map(String).map(s => s.trim()).join(" ");

const isValidPadding = (s: string) =>
  s.split(/\s+/).every((t) => /^(?:[a-z]+:)?p[bt]-(?:px|0|[1-9]\d*)$/.test(t));

const padding = (section.paddingClass ?? "").trim();
if (!padding) throw new Error('[offlineAddressesEnglishSection] Missing required "paddingClass" from Sanity');
if (!isValidPadding(padding)) throw new Error('[offlineAddressesEnglishSection] Invalid "paddingClass" value');
---

<section 
  id={anchorId} 
  class={join(bgClass, padding)}
  data-watch="fade-to-top" 
  data-watch-repeat
  data-watch-delay="320"
  data-watch-duration="1000"  
>
  <div class="container">
    {section.heading && (
      <div class="mb-9">
        <h2 class="font-secondary font-medium text-2xl lg:text-4xl text-center">
          {section.heading}
        </h2>
      </div>
    )}

    <div class="mb-11">
      <EmblaCarousel options={{ breakpoints: { "(min-width: 1272px)": { active: false } } }}>
        <Fragment slot="slides">
          {items.map((it) => (
            <div class="min-w-full lg:min-w-0 embla__slide">
              {it?.href ? (
                <a href={it.href} target="_blank" rel="noopener noreferrer" class="block h-full">
                  <div class="flex flex-col items-center gap-5 shadow-lg px-6 py-6 rounded-lg h-full">
                    {it?.image?.url && (
                      <img
                        class="rounded-lg"
                        src={it.image.url}
                        alt={it.image.alt ?? ""}
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                    {it?.title && (
                      <h3 class="font-secondary font-semibold text-base lg:text-lg text-center uppercase">
                        {it.title}
                      </h3>
                    )}
                    {(it?.address || it?.phone) && (
                      <Article class="max-w-xs font-normal text-center">
                        {it.address && <p>{it.address}</p>}
                        {it.phone && <p>{it.phone}</p>}
                      </Article>
                    )}
                  </div>
                </a>
              ) : (
                <div class="h-full">
                  <div class="flex flex-col items-center gap-5 shadow-lg px-6 py-6 rounded-lg h-full">
                    {it?.image?.url && (
                      <img
                        class="rounded-lg"
                        src={it.image.url}
                        alt={it.image.alt ?? ""}
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                    {it?.title && (
                      <h3 class="font-secondary font-semibold text-base lg:text-lg text-center uppercase">
                        {it.title}
                      </h3>
                    )}
                    {(it?.address || it?.phone) && (
                      <Article class="max-w-xs font-normal text-center">
                        {it.address && <p>{it.address}</p>}
                        {it.phone && <p>{it.phone}</p>}
                      </Article>
                    )}
                  </div>
                </div>
              )}
            </div>
          ))}
        </Fragment>

        <Fragment slot="controls">
          <div class="lg:hidden flex justify-center items-center gap-3 mt-4">
            <button class="embla__prev" type="button" aria-label="Previous slide">
              <Image class="w-6 h-6" src={import("@images/embla-prev-svg.svg")} alt="prev-btn" />
            </button>
            <div class="flex justify-center items-center gap-1 bg-gray rounded-2xl w-24 h-9" aria-live="polite" aria-atomic="true">
              <p class="font-bold text-primary-orange embla-current"></p>
              <p class="font-bold">/</p>
              <p class="font-bold embla-total"></p>
            </div>
            <button class="embla__next" type="button" aria-label="Next slide">
              <Image class="w-6 h-6" src={import("@images/embla-next-svg.svg")} alt="next-btn" />
            </button>
          </div>
        </Fragment>
      </EmblaCarousel>
    </div>
  </div>
</section>
