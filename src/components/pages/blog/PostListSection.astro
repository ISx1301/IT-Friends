---
import PostCard from '@components/PostCard.astro';
import postImage from '@images/post-image.png';

export interface Post {
  slug: string;
  title: string;
  image: typeof postImage;  
  content: string;
  date: string;
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props as Props;
---
<section class="py-20">
  <div class="container">
    <div class="gap-x-5 gap-y-16 grid lg:grid-cols-3 grid-col-1 mb-11 posts-container">
      {posts.map((post: Post) => (
        <div class="hidden post-card">
          <PostCard post={post} />
        </div>
      ))}
    </div>

    <div class="flex justify-center">
      <button type="button" class="px-20 py-3 transparent-btn load-more-btn">Далі</button>
    </div>    
        
  </div>
</section>


<script>
  import { setupLoadMorePostsByClasses } from '@scripts/posts';

  setupLoadMorePostsByClasses();
</script>

