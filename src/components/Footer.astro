---
import { Image } from "astro:assets";
import FooterLogo from "@images/logo-footer.jpg";
import Facebook from "@images/facebook.svg";
import Instagram from "@images/instagram.svg";
import Telegram from "@images/telegram.svg";
---

<div class="pt-12 lg:pt-9 pb-5 lg:pb-11 container">
  <div class="flex lg:flex-row flex-col mb-5 w-full">

    <div class="flex flex-col items-center lg:items-start order-1 basis-1/4 lg:basis-3/12 shrink-0">
      <a class="mb-3 lg:mb-7" href="#"><Image src={FooterLogo} alt="FooterLogo" /></a>
      <p class="mb-1 lg:mb-2 leading-5">
        IT‑школа для дітей і <span class="hidden lg:inline"><br /></span> підлітків
        7–16 років.
      </p>
      <p class="lg:text-left text-center leading-5">
        Вчимо зрозуміло, <span class="hidden lg:inline"><br /></span> підтримуємо
        інтерес, <br /> допомагаємо знайти своє.
      </p>
    </div>

    <div class="order-3 lg:order-2 pt-7 basis-1/4 lg:basis-1/12 shrink-0">
      <ul class="space-y-2 font-secondary">
        <li class="font-semibold text-lg lg:text-left text-center">
          <a href="#">Курси</a>
        </li>
        <li class="font-semibold text-lg lg:text-left text-center">
          <a href="#">Про Нас</a>
        </li>
        <li class="font-semibold text-lg lg:text-left text-center">
          <a href="#">Відгуки</a>
        </li>
        <li class="font-semibold text-lg lg:text-left text-center">
          <a href="#">FAQ</a>
        </li>
      </ul>
    </div>

    <div class="order-3 pt-0 lg:pt-7 pl-0 lg:pl-16 basis:1/4 lg:basis-2/12 shrink-0">
      <ul class="space-y-2 font-secondary">
        <li class="font-semibold text-lg lg:text-left text-center">
          <a href="#">Блог</a>
        </li>
        <li class="font-semibold text-lg lg:text-left text-center">
          <a href="#">Контакти</a>
        </li>
      </ul>
    </div>

    
    <div class="order-5 lg:order-4 pt-0 lg:pt-7 pl-0 lg:pl-14 basis:1/4 lg:basis-4/12 shrink-0">
      <ul class="space-y-2 font-secondary">
        <li class="font-semibold text-lg lg:text-left text-center">
          <a href="#">Політика Конфіденційності</a>
        </li>
        <li class="font-semibold text-lg lg:text-left text-center">
          <a href="#">Угода Користувача</a>
        </li>
      </ul>
    </div>

    
    <div class="flex flex-col items-center lg:items-end gap-10 order-2 lg:order-5 pt-12 lg:pt-custom-padding-btn basis:1/4 lg:basis-2/12 shrink-0">
      <button class="order-2 lg:order-1 px-footer-btn py-custom-padding-btn2 pt- border-none orange-btn">Спробувати</button>
      <div class="flex justify-center lg:justify-between gap-16 lg:gap-0 order-1 lg:order-2 pl-0 lg:pl-[1rem] w-full">
        <a href="#"><Facebook class="w-[1.75rem] h-[1.75rem]" /></a>
        <a href="#"><Facebook class="w-[1.75rem] h-[1.75rem]" /></a>
        <a href="#"><Facebook class="w-[1.75rem] h-[1.75rem]" /></a>
      </div>
    </div>
  </div>

  <div class="flex justify-center w-full">
    <p class="font-normal text-sm lg:text-base">
      © 2025 IT-школа “IT Friends”. Усі права захищені.
    </p>
  </div>
  
</div>
