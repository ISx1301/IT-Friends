---
import { Image } from "astro:assets";
import "@styles/global.scss";

import {
  DEFAULT_LANG,
  type Lang,
  LOCALE,
  DIRECTION_OPTIONS,
  CAMPS,
  CAMP_ORDER,
} from "@/constants";

interface Props { lang?: Lang }

const { lang = DEFAULT_LANG as Lang } = Astro.props;
const t = LOCALE[lang];
const ui = t.ui;
const directions = DIRECTION_OPTIONS[lang];
---

<div class="right-0 bottom-1 z-10 fixed flex flex-col gap-2">
  <button type="button" class="qc-phone-btn" aria-label={ui.callAlt}>
    <Image src={import("@images/call-btn.svg")} format="svg" alt={ui.callAlt} />
  </button>
  <button type="button" class="qc-telegram-btn" aria-label={ui.telegramAlt}>
    <Image src={import("@images/telegram-btn.svg")} format="svg" alt={ui.telegramAlt} />
  </button>
</div>

<div class="top-0 left-0 z-50 fixed flex justify-center items-center w-full h-screen overflow-y-auto transition-transform -translate-x-full duration-300 ease-in-out transform qc-direction-menu">
  <div class="flex justify-center items-center h-screen overflow-y-auto qc-direction-menu-close">
    <div class="left-0 absolute bg-white/10 backdrop-blur-md w-full h-screen overflow-y-auto"></div>

    <div class="relative flex flex-col items-center bg-white lg:shadow-2xl px-3 lg:px-14 py-9 rounded-lg w-11/12 lg:w-full">
      <div class="top-4 right-4 absolute cursor-pointer qc-direction-menu-close" aria-label={ui.close}>
        <Image src={import("@images/green-close.svg")} format="svg" alt={ui.close} />
      </div>

      <div class="mb-5">
        <h2 class="font-secondary font-medium text-xl text-center">{ui.phoneMenuTitle}</h2>
      </div>

      <div class="flex flex-col items-center gap-4 w-full">
        {directions.map((opt) => (
          <button
            type="button"
            class="py-5 border rounded-lg w-full font-medium text-lg text-center qc-pick-direction"
            data-direction={opt.key}
          >
            {opt.label}
          </button>
        ))}
      </div>
    </div>
  </div>
</div>

<div class="top-0 left-0 z-50 fixed flex justify-center items-center w-full h-screen overflow-y-auto transition-transform -translate-x-full duration-300 ease-in-out transform qc-address-panel">
  <div class="flex justify-center items-center h-screen overflow-y-auto qc-address-panel-close">
    <div class="left-0 absolute bg-white/10 backdrop-blur-md w-full h-screen overflow-y-auto"></div>

    <div class="relative flex flex-col items-center bg-white lg:shadow-2xl px-3 lg:px-14 py-9 rounded-lg w-11/12 lg:w-full">
      <div class="top-4 right-4 absolute cursor-pointer qc-address-panel-close" aria-label={ui.close}>
        <Image src={import("@images/green-close.svg")} format="svg" alt={ui.close} />
      </div>

      <div class="mb-5">
        <h2 class="font-secondary font-medium text-xl text-center">{t.form.addressTitle}</h2>
      </div>

      <div class="flex flex-col gap-4 w-full qc-address-list"></div>
    </div>
  </div>
</div>

<div class="top-0 left-0 z-50 fixed flex justify-center items-center w-full h-screen overflow-y-auto transition-transform -translate-x-full duration-300 ease-in-out transform qc-camps-panel">
  <div class="flex justify-center items-center h-screen overflow-y-auto qc-camps-panel-close">
    <div class="left-0 absolute bg-white/10 backdrop-blur-md w-full h-screen overflow-y-auto"></div>

    <div class="relative flex flex-col items-center bg-white lg:shadow-2xl px-3 lg:px-14 py-9 rounded-lg w-11/12 lg:w-full">
      <div class="top-4 right-4 absolute cursor-pointer qc-camps-panel-close" aria-label={ui.close}>
        <Image src={import("@images/green-close.svg")} format="svg" alt={ui.close} />
      </div>

      <div class="mb-5">
        <h2 class="font-secondary font-medium text-xl text-center">Оберіть табір</h2>
      </div>

      <div class="flex flex-col gap-4 w-full">
        {CAMP_ORDER.map((id) => (
          <a
            class="py-3 px-4 border rounded-lg w-full font-medium text-base text-center qc-camp-link"
            href="#"
            data-phone={CAMPS[id].phoneHref}
            data-telegram={CAMPS[id].telegram}
          >
            <span class="block font-semibold">{CAMPS[id].label}</span>
            <span class="block text-sm text-gray-500">{CAMPS[id].phone}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<script src="@/scripts/contacts.ts" />
