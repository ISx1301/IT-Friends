---
import "@styles/global.scss";
// Components
import HeadBase from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro"
import FreeLessonForm from "@components/FreeLessonForm.astro";
import Contacts from "@/components/Contacts.astro";

const { settings, lang, seo } = Astro.props;
---

<html class="scroll-smooth" lang="en">
  <HeadBase {...seo} />

  <body class="flex flex-col min-h-[100svh]">
    <Header data={settings?.header} lang={lang}/>

    <Contacts />

    <FreeLessonForm />

    <main aria-label="Content">
      <slot />
    </main>

    
    <Footer data={settings?.footer} lang={lang}/>
    <!-- <script type="module" src="/src/scripts/app.ts"></script> -->
  </body>
  <script>
    // import "@scripts/app.ts";
  </script>
</html>

