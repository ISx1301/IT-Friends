---
import "../styles/global.scss";
// Components
import HeadBase from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro"

const { title, description, image } = Astro.props;
---

<!-- TODO: get current page language from Astro.props -->
<html class="scroll-smooth" lang="en">
  <HeadBase title={title} description={description} image={image} />

  <body class="flex flex-col min-h-[100svh]">
    <Header />

    <main aria-label="Content">
      <slot />
    </main>

    <!-- TODO: include footer component -->
    <Footer />
  </body>
  <script>
    // import "@scripts/app.ts";
  </script>
</html>

