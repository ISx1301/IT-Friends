          <!-- first card -->
          <div class="flex lg:flex-row flex-col lg:justify-between items-center gap-5 lg:gap-0 bg-white shadow-none lg:shadow-md ml-auto border border-gray lg:border-none rounded-md w-[31rem] min-w-full lg:min-w-0 snap-center">
            <div class="bg-primary-green rounded-md w-full lg:w-2 h-2 lg:h-full"></div>
            <div class="my-3">
