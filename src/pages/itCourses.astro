---
import { Image } from "astro:assets";
import DefaultLayout from "@layouts/Default.astro";
import Tab from "@components/Tab.astro";
import Article from "@components/Article.astro";


import { SITE_TITLE, SITE_DESCRIPTION } from "@/constants.ts";
const title = `${SITE_TITLE}`;
const description = `${SITE_DESCRIPTION}`;
---

<DefaultLayout title={title} description={description}>

  <!-- Hero section -->

  <section class="mt-11 lg:mt-16">
    <div class="container">

      <div class="flex justify-center bg-transparent-btn-hover-bg mx-auto mb-6 lg:mb-8 py-0.5 w-[21.56rem]">
        <p>Більше, ніж уроки — досвід спілкування</p>
      </div>
      
      <div>
        <h1 class="mb-6 lg:mb-7 font-secondary font-medium text-2xl lg:text-4xl text-center">IT‑заняття для дітей і підлітків</h1>
      </div>

      <div class="mx-auto mb-6 lg:mb-11 max-w-sm">
        <p class="font-normal text-lg text-center">Вчимо створювати, а не лише користуватися</p>
      </div>


      <div class="mb-6 lg:mb-0 rounded-xl w-full h-full aspect-40/17 overflow-hidden">
        <Image
          class="brightness-75 w-full h-full object-cover animate-zoom-pulse"
          src={import("@images/it-courses-main.png")}
          format="webp"
          alt="image"
        />
      </div>

      <div class="lg:hidden justify-center basis-1/4 lg:basis-1/12">
        <button class="px-5 py-4 font-secondary font-medium text-lg orange-btn" type="button">Безкоштовний урок</button>
      </div>

    </div>
  </section>

  <!-- Target audience section -->

  <section class="my-20 lg:my-28">
    <div class="container">

      <div class="flex justify-center mx-auto mb-6 lg:mb-8 py-0.5">
        <h2 class="mb-6 lg:mb-7 font-secondary font-medium text-2xl lg:text-4xl text-center">Для кого підходять заняття</h2>
      </div>

      <div class="flex lg:flex-row flex-col items-center gap-5">

        <div class="flex flex-col items-center gap-7 shadow-lg px-8 lg:px-6 py-10 rounded-lg basis-1/4 lg:basis-3/12">
          <Image
            src={import("@images/target-pic.png")}
            format="webp"
            alt="image"
          />
          <p class="font-medium text-base lg:text-lg text-center">Діти 7–9 років, які роблять перші кроки в IT</p>
        </div>

        <div class="flex flex-col items-center gap-7 shadow-lg px-8 lg:px-6 py-10 rounded-lg basis-5/6 lg:basis-3/12">
          <Image
            src={import("@images/target-pic.png")}
            format="webp"
            alt="image"
          />
          <p class="font-medium text-base lg:text-lg text-center">Підлітки 10–14 років, що цікавляться технологіями</p>
        </div>

        <div class="flex flex-col items-center gap-7 shadow-lg px-8 lg:px-8 py-10 rounded-lg basis-5/6 lg:basis-3/12">
          <Image
            src={import("@images/target-pic.png")}
            format="webp"
            alt="image"
          />
          <p class="font-medium text-base lg:text-lg text-center">Ті, хто хоче навчитися створювати ігри, сайти чи анімації</p>
        </div>

        <div class="flex flex-col items-center gap-7 shadow-lg px-8 lg:px-6 py-10 rounded-lg basis-5/6 lg:basis-3/12">
          <Image
            src={import("@images/target-pic.png")}
            format="webp"
            alt="image"
          />
