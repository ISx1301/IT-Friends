---

<DefaultLayout title={title} description={description}>

  <HeroSection {...heroSectionData}/> 
  

  <AreasOfStudy {...areasStudyData} />


  <AboutSection {...aboutSectionData} />


  <PeculiaritiesSection {...peculiaritiesSectionData} />


  <ReviewsSection {...reviewsSectionData} />

  
  <NewSchoolMain  {...imageNewSchoolData}/>
  
  
  
  <!-- Team section -->

  <section class="py-16 lg:py-32 w-full overflow-hidden">
    <div class="container">
      <div class="m-auto mb-16 max-w-lg">
        <h2 class="mb-8 font-secondary font-medium text-2xl lg:text-4xl text-center">Наша команда</h2>
        <p class="font-normal text-base text-center">Наші викладачі не просто навчають — вони надихають, пояснюють складне простими словами та допомагають кожній дитині розкрити свій потенціал.</p>
      </div>

      <div class="flex gap-4 lg:gap-5 pb-4 lg:overflow-hidden overflow-x-auto scroll-smooth snap-mandatory snap-x lg:snap-none">

        <div class="flex flex-col gap-6 min-w-full lg:min-w-0 snap-center basis-full lg:basis-1/3">
          <div class="rounded-full aspect-59/84">
            <Image
              class="rounded-full w-full h-full object-cover"
              src={import("@images/teacher.png")}
              format="webp"
              alt="IT Friends logo"
            />
          </div>
          <div class="flex flex-col items-center">
            <h3 class="font-medium text-lg">Ірина Маринова</h3>
            <p class="text-base">Вчителька англійської</p>
            <a href="#">
              <Image
                class="w-7 h-7"
                src={import("@images/facebook.svg")}
                alt="Facebook picture"
              />
            </a>
          </div>
        </div>
        
        <div class="flex flex-col lg:flex-col-reverse gap-6 pt-0 lg:pt-16 min-w-full lg:min-w-0 snap-center basis-full lg:basis-1/3">
          <div class="rounded-full aspect-59/84">
            <Image
              class="rounded-full w-full h-full object-cover"
              src={import("@images/teacher.png")}
              format="webp"
