---
import { DEFAULT_LANG } from '@/constants';

export const prerender = false;

const raw = (typeof Astro.cookies?.get === 'function')
  ? Astro.cookies.get('language')?.value
  : undefined;

const lang = (raw === 'uk' || raw === 'en') ? raw : DEFAULT_LANG;

const location = new URL(`/${lang}/`, Astro.request.url).toString();
return Astro.redirect(location, 308);
---
