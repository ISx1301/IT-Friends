---
import DefaultLayout from "@layouts/Default.astro";
import { DEFAULT_LANG } from '@/constants';

import { query } from '../../../lib/sanity';
import { BLOG_POST_WITH_SETTINGS } from '../../../lib/queries';
import NotFound from '../../404.astro';

type Post = {
  title: string;
  image?: { url?: string; alt?: string };
  content?: any;
  date?: string;
  seo?: { title: string; description?: string | null; image?: string | null };
};
type SettingsDoc = { header?: any; footer?: any };
type Data = { post: Post | null; settings: SettingsDoc | null };

export const prerender = false;

const { lang = DEFAULT_LANG, slug = '' } = Astro.params;
const LOCALES = new Set(['uk','en']);

let notFound = false;
let post: Post | null = null;
let settings: SettingsDoc | null = null;

if (!LOCALES.has(String(lang).toLowerCase())) {
  notFound = true;
  Astro.response.status = 404;
} else {
  const data = await query<Data>(BLOG_POST_WITH_SETTINGS, { lang, slug });
  if (!data?.post) {
    notFound = true;
    Astro.response.status = 404;
  } else {
    post = data.post;
    settings = data.settings ?? null;
  }
}

const seo = post?.seo ?? {
  title: post?.title ?? 'Post',
  description: undefined,
  image: post?.image?.url ?? null
};
---
{ notFound ? (
  <NotFound />
) : (
  <DefaultLayout settings={settings!} lang={lang} seo={seo}>
    <article class="py-10 container">
      <h1 class="mb-6 font-secondary font-medium text-3xl lg:text-5xl">{post!.title}</h1>
      {post?.image?.url && (
        <img src={post.image.url} alt={post.image.alt ?? post.title} class="mx-auto mb-6 max-w-full" />
      )}
    </article>
  </DefaultLayout>
)}
