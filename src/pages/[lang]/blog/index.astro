---
import { query } from '../../../lib/sanity';
import { PAGE_WITH_SETTINGS } from '../../../lib/queries';
import DefaultLayout from "@layouts/Default.astro";
import { DEFAULT_LANG } from '@/constants';
import { sectionsRegistry } from '../../../lib/sections-registry';

type SeoHead = { title: string; description?: string | null; image?: string | null }
type Section = { _type: string; _key?: string } & Record<string, any>
type PageDoc = { _id: string; title: string; sections?: Section[]; seo: SeoHead }
type SettingsDoc = { header?: any; footer?: any }
type PageData = { page: PageDoc | null; settings: SettingsDoc | null }

const { lang = DEFAULT_LANG } = Astro.params;
const slug = 'blog';

// строим пути по ДОКУМЕНТАМ page со слагом "blog"
export async function getStaticPaths() {
  const rows = await query<{ lang: string; rawSlug: string }[]>(/* groq */`
    *[
      _type == "page" && defined(slug.current) && defined(language)
    ]{ "lang": language, "rawSlug": slug.current }
  `);

  if (!rows?.length) return [];

  const langs = new Set<string>();
  for (const { lang, rawSlug } of rows) {
    let s = String(rawSlug || '').replace(/^\/+|\/+$/g, '');
    if (s.startsWith(`${lang}/`)) s = s.slice(lang.length + 1);
    if (s.includes('/')) s = s.split('/').pop() as string;
    if (s === 'blog') langs.add(lang);
  }
  return Array.from(langs).map((lang) => ({ params: { lang } }));
}

// ВАЖНО: передаём fallbackLang (дефолт — uk)
// Если в EN нет статей — в секции постов подставятся украинские, чтобы секция не пустовала
const data = await query<PageData>(PAGE_WITH_SETTINGS, { lang, slug, fallbackLang: DEFAULT_LANG });

if (!data?.page) {
  return Astro.redirect(`/404`, 302);
}

const { page, settings } = data;
---

<DefaultLayout settings={settings} lang={lang} seo={page!.seo}>
  {
    page?.sections?.map((sec, index) => {
      const Cmp = sectionsRegistry[sec._type];
      const anchorId = `section${index + 1}`;
      return Cmp
        ? <Cmp section={sec} anchorId={anchorId}/>
        : <section class="py-6"><div class="container">Unknown section: {sec._type}</div></section>
    })
  }
</DefaultLayout>
