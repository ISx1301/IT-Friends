  <WithoutNestedTabsSection />

  <PeculiaritiesSection {...peculiaritiesSectionData} />

  <ReviewsSection {...reviewsSectionData} />

  <TeamSection />

  <AccordionSection />

  <InterestingThingsSection />

</DefaultLayout>
