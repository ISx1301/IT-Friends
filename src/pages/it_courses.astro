import TabsSection from "@components/sharedSections/TabsSection.astro";
import PeculiaritiesSection from "@components/sharedSections/PeculiaritiesSection.astro";
import ReviewsSection from "@components/sharedSections/ReviewsSection.astro";




import { SITE_TITLE, SITE_DESCRIPTION } from "@/constants.ts";
const title = `${SITE_TITLE}`;
const description = `${SITE_DESCRIPTION}`;


// Peculiarities section data 
  type ImagePeculiaritiesType = {
    src: ImageMetadata;
    alt?: string;
  };

  type cardItemFirstBlock = {
    image: ImagePeculiaritiesType;
    subHeading: string;
    description: string;
  }

  type cardItemSecondBlock = {
    image: ImagePeculiaritiesType;
    subHeading: string;
    description: string;
  }

  type peculiaritiesSectionProps = {
    sectionPaddingsStyle: 'withPaddings' | 'withoutPaddings';
    sectionBgStyle: 'gradient' | 'gray';
    titleText: string;
    leftCard: cardItemFirstBlock[];
    mainImage: ImagePeculiaritiesType;
    rightCard: cardItemSecondBlock[];
  }

  const peculiaritiesSectionData: peculiaritiesSectionProps = {
    sectionPaddingsStyle: 'withPaddings',
    sectionBgStyle: 'gray',
    titleText: 'Що робить нашу школу особливою',
    leftCard: [
      {
        image: {
          src: peculiaritiesImg1,
          alt: 'qwerty'
        },
        subHeading: 'Великий  вибір напрямків',
        description: 'Ми створили школу, в якій дитину не оцінюють, а підтримують.Тут кожен учень — важливий.'
      },
      {
        image: {
          src: peculiaritiesImg1,
          alt: 'qwerty'
