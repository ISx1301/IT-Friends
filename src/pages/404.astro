---
import ErrorLayout from "@layouts/Error.astro";
import { DEFAULT_LANG, LOCALE } from "@/constants";
import type { Lang } from "@/constants";
import { Image } from "astro:assets";
import logo404 from "@images/logo404.png";

export const prerender = false;

const isLang = (v: unknown): v is Lang => v === "uk" || v === "en";
const raw = (typeof Astro.cookies?.get === "function")
  ? Astro.cookies.get("language")?.value
  : undefined;
const lang: Lang = isLang(raw) ? raw : (DEFAULT_LANG as Lang);

const t = LOCALE[lang];
const description = t.notFoundText;
const btn404 = t.btn404;
---
<ErrorLayout description={description} btn={btn404}>
  <div class="place-items-center grid min-h-dvh">
    <div class="container">
      <div class="flex flex-col items-center">
        <Image class="mx-auto lg:aspect-2/1" src={logo404} format="webp" alt="logo404" />
        <h1 class="lg:mb-9 font-secondary font-medium text-2xl lg:text-4xl">404</h1>
        <p class="mb-14 lg:max-w-xl font-secondary font-medium text-2xl lg:text-4xl text-center">
          {t.notFoundText}
        </p>
        <a href="/"><button class="px-32 py-5 orange-btn" type="button">{t.btn404}</button></a>
      </div>
    </div>
  </div>
</ErrorLayout>